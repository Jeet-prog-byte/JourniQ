{
  "builds": [
    { "src": "client/package.json", "use": "@vercel/static-build" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/auth(.*)", "dest": "/api/auth.js" },
    { "src": "/api/packages(.*)", "dest": "/api/packages.js" },
    { "src": "/api/bookings(.*)", "dest": "/api/bookings.js" },
    { "src": "/api/reviews(.*)", "dest": "/api/reviews.js" },
    { "src": "/api/admin(.*)", "dest": "/api/admin.js" },
    { "src": "/api/chat(.*)", "dest": "/api/chat.js" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ]
}
